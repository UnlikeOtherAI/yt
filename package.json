{
  "name": "@unlikeotherai/yt",
  "version": "0.1.5",
  "description": "CLI for YouTube research ingestion, transcript storage, and article generation.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "yt": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UnlikeOtherAI/yt.git"
  },
  "bugs": {
    "url": "https://github.com/UnlikeOtherAI/yt/issues"
  },
  "homepage": "https://github.com/UnlikeOtherAI/yt#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm lint && pnpm typecheck && tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "dev": "tsx src/cli.ts",
    "help": "tsx src/cli.ts --help",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.17.0",
    "commander": "^14.0.0",
    "dotenv": "^16.6.1",
    "p-limit": "^7.1.1",
    "pino": "^10.0.0",
    "youtube-transcript-plus": "^1.1.6",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^24.3.0",
    "eslint": "^9.35.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^16.4.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vitest": "^3.2.4"
  }
}
